# ─────────────────────────────────────────────────────────────────────────────
# Synapse Agentic GTM System — Environment Variable Template
# Copy this to `.env.local` (never commit .env.local to git)
# ─────────────────────────────────────────────────────────────────────────────

# ── Google Cloud Platform ─────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1
# Path to your GCP service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account.json

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
# Service role key — NEVER expose to the browser (server-side only)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── HubSpot OAuth ─────────────────────────────────────────────────────────────
HUBSPOT_CLIENT_ID=your_hubspot_client_id
HUBSPOT_CLIENT_SECRET=your_hubspot_client_secret
NEXT_PUBLIC_APP_URL=http://localhost:3000
HUBSPOT_CODE_VERIFIER=your_pkce_code_verifier

# ── Apollo.io ─────────────────────────────────────────────────────────────────
# Get from https://app.apollo.io/#/settings/integrations/api
APOLLO_API_KEY=your_apollo_api_key

# ── Clay.com ──────────────────────────────────────────────────────────────────
# Webhook URL from your Clay table "Pull in data from webhook" source
CLAY_WEBHOOK_URL=https://api.clay.com/v3/sources/webhook/your-webhook-id

# ── Slack ─────────────────────────────────────────────────────────────────────
# Bot token from https://api.slack.com/apps → Your App → OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# ── Notion ────────────────────────────────────────────────────────────────────
# Internal integration token from https://www.notion.so/my-integrations
NOTION_API_KEY=ntn_your_notion_integration_token

# ── Gumloop ───────────────────────────────────────────────────────────────────
GUMLOOP_API_KEY=your_gumloop_api_key
GUMLOOP_USER_ID=your_gumloop_user_id

# ── Google Ads ────────────────────────────────────────────────────────────────
# OAuth credentials from Google Cloud Console
GOOGLE_ADS_CLIENT_ID=your_oauth_client_id.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=your_oauth_client_secret
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token
# From Google Ads API Center: https://developers.google.com/google-ads/api/docs/first-call/dev-token
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token
# Google Ads Customer ID (format: XXX-XXX-XXXX)
GOOGLE_ADS_CUSTOMER_ID=000-000-0000
# Manager account ID if using MCC
GOOGLE_ADS_LOGIN_CUSTOMER_ID=000-000-0000

# ── Meta Ads ──────────────────────────────────────────────────────────────────
# From https://developers.facebook.com → Your App → Marketing API
META_ADS_ACCESS_TOKEN=your_meta_long_lived_access_token
# Format: act_XXXXXXXXXXXXXXXXX
META_ADS_AD_ACCOUNT_ID=act_your_ad_account_id

# ── Make.com (MCP Toolbox) ────────────────────────────────────────────────────
MAKE_API_TOKEN=your_make_api_token
MAKE_TOOLBOX_ID=your_make_toolbox_id

# ── SEO & Content ─────────────────────────────────────────────────────────────
# Ahrefs API v3: https://ahrefs.com/api
AHREFS_API_KEY=your_ahrefs_v3_api_key
# SEMrush: https://www.semrush.com/api-documentation/
SEMRUSH_API_KEY=your_semrush_api_key

# ── Social — Direct APIs ──────────────────────────────────────────────────────
# LinkedIn: https://developer.linkedin.com → Your App → Auth → Access Token
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token
# Meta/Instagram: same app as Meta Ads, request instagram_basic + instagram_content_publish scopes
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_ig_business_account_id

# ── Events & Webinars ─────────────────────────────────────────────────────────
# Zoom: https://marketplace.zoom.us → Your App → Credentials
ZOOM_API_KEY=your_zoom_api_key
ZOOM_API_SECRET=your_zoom_api_secret
# Google Sheet ID for webinar registration fallback
WEBINAR_REGISTRATION_SHEET_ID=your_google_sheet_id

# ── PLG & Marketing Intelligence ──────────────────────────────────────────────
# PostHog: https://app.posthog.com → Project Settings → API Keys
POSTHOG_API_KEY=your_posthog_project_api_key
POSTHOG_PROJECT_ID=your_posthog_project_id
# GA4: https://analytics.google.com → Admin → Property → Property ID
GA4_PROPERTY_ID=your_ga4_property_id
